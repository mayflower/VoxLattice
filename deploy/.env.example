# Generate a local value; do not use a shared or production credential here.
FASTENHANCER_API_TOKEN=

# GPU UUID or index reported by `nvidia-smi -L`.
FASTENHANCER_GPU_DEVICE_ID=

# Use the published image with `docker compose pull` and `up --no-build`.
# Leave unset when using the source-based `make up` and `make compose-test`.
# VOXLATTICE_IMAGE=ghcr.io/mayflower/voxlattice:latest

# Optional host bindings for long-running `make up`; the Compose smoke test
# uses ephemeral ports to avoid collisions.
FASTENHANCER_GRPC_PORT=50051
FASTENHANCER_HTTP_PORT=8080
FASTENHANCER_GRPC_BIND_ADDRESS=127.0.0.1
FASTENHANCER_HTTP_BIND_ADDRESS=127.0.0.1

# Optional server limits. Benchmark the target deployment before increasing
# concurrency or queue sizes.
MAX_ACTIVE_STREAMS=128
MAX_BATCH_SIZE=32
MAX_BATCH_WAIT_MS=1
MAX_PENDING_AUDIO_MS_PER_STREAM=500
MAX_OUTPUT_AUDIO_MS_PER_STREAM=500
STREAM_IDLE_TIMEOUT_S=30
MAX_AUDIO_CHUNK_SAMPLES=16000
GRACEFUL_SHUTDOWN_S=10

# TLS is enabled with deploy/docker-compose.tls.yml. These paths are read from
# the host and must not point into the repository.
# FASTENHANCER_TLS_CERTIFICATE=/etc/voxlattice/server.crt
# FASTENHANCER_TLS_PRIVATE_KEY=/etc/voxlattice/server.key
# FASTENHANCER_TLS_CLIENT_CA=/etc/voxlattice/client-ca.crt
