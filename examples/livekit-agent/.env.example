LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Local VoxLattice Compose server. Use tls=true and a DNS endpoint remotely.
FASTENHANCER_ENDPOINT=127.0.0.1:50051
FASTENHANCER_API_TOKEN=
FASTENHANCER_TLS=false
FASTENHANCER_USE_SELECTOR=true

# Optional private-CA or mTLS files.
# FASTENHANCER_ROOT_CERTIFICATE=/run/secrets/server-ca.pem
# FASTENHANCER_CLIENT_CERTIFICATE=/run/secrets/client.crt
# FASTENHANCER_CLIENT_PRIVATE_KEY=/run/secrets/client.key
